@page
@model RazorApp.Pages.Admin.ManageUsersModel
@{
    ViewData["Title"] = "Manage Users";
}

<h2>Manage Users</h2>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">@TempData["SuccessMessage"]</div>
}

<table class="table table-striped">
    <thead>
        <tr>
            <th>Username</th>
            <th>Email</th>
            <th>Current Roles</th>
            <th>Change Role</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var user in Model.Users)
        {
            var roles = string.Join(", ", await Model.UserManagerInstance.GetRolesAsync(user));
            <tr>
                <td>@user.UserName</td>
                <td>@user.Email</td>
                <td>@roles</td>
                <td>
                    <form method="post">
                        <input type="hidden" asp-for="SelectedUserId" value="@user.Id" />
                        <select asp-for="SelectedRole" class="form-select form-select-sm">
                            @foreach (var role in Model.Roles)
                            {
                                <option value="@role" selected="@(roles.Contains(role) ? "selected" : "")">@role</option>
                            }
                        </select>
                        <button type="submit" class="btn btn-sm btn-primary mt-1">Update</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>