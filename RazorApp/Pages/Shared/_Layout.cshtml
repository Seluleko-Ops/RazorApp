@using Microsoft.AspNetCore.Identity
@inject SignInManager<RazorApp.Models.ApplicationUser> SignInManager
@inject UserManager<RazorApp.Models.ApplicationUser> UserManager

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - RazorApp</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/RazorApp.styles.css" asp-append-version="true" />

    <style>
        /* ===== Base ===== */
        html, body {
            margin: 0;
            height: 100%;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            color: #2e3a59;
            overflow: hidden;
            transition: background 0.3s, color 0.3s;
        }
        body.dark-mode {
            background: #121212;
            color: #ffffff; /* default text */
        }
        
        /* Sidebar, buttons, main content, footer, cards */
        body.dark-mode nav.sidebar,
        body.dark-mode main.main-content,
        body.dark-mode footer.footer,
        body.dark-mode .glass-card,
        body.dark-mode .modal-content {
            color: #ffffff;
            background: rgba(50, 50, 50, 0.85); /* Glass effect */
            border-color: rgba(120,120,120,0.4);
        }
        
        /* Headings and paragraph text */
        body.dark-mode h1, body.dark-mode h2, body.dark-mode h3,
        body.dark-mode h4, body.dark-mode h5, body.dark-mode h6,
        body.dark-mode p, body.dark-mode label, body.dark-mode span,
        body.dark-mode small, body.dark-mode strong {
            color: #ffffff !important;
        }
        
        /* Tables */
        body.dark-mode table {
            color: #ffffff; /* text */
            background: rgba(50,50,50,0.7);
            border-color: rgba(120,120,120,0.5);
        }
        
        body.dark-mode table th,
        body.dark-mode table td {
            color: #ffffff !important;
            border-color: rgba(120,120,120,0.5) !important;
        }
        
        body.dark-mode table thead th {
            background: rgba(70,70,70,0.8) !important;
        }
        
        body.dark-mode table tbody tr {
            background: rgba(50,50,50,0.6) !important;
        }
        
        body.dark-mode table tbody tr:nth-child(even) {
            background: rgba(60,60,60,0.6) !important;
        }
        
        /* Form inputs and selects */
        body.dark-mode input.form-control,
        body.dark-mode select.form-select,
        body.dark-mode textarea.form-control {
            background: rgba(70,70,70,0.8);
            color: #ffffff;
            border: 1px solid rgba(200,200,200,0.5);
        }
        
        body.dark-mode input::placeholder,
        body.dark-mode textarea::placeholder {
            color: #cccccc;
        }
        
        /* Alerts */
        body.dark-mode .alert {
            color: #ffffff !important;
            background-color: rgba(70,70,70,0.8) !important;
            border-color: rgba(120,120,120,0.5) !important;
        }
        
        /* Buttons */
        body.dark-mode .btn,
        body.dark-mode .btn-primary,
        body.dark-mode .btn-success,
        body.dark-mode .btn-secondary,
        body.dark-mode .btn-danger,
        body.dark-mode .btn-warning,
        body.dark-mode .btn-edit,
        body.dark-mode .btn-delete,
        body.dark-mode .btn-glass {
            color: #ffffff !important;
        }
        
        /* Links inside dark mode */
        body.dark-mode a {
            color: #ffffff !important;
        }
        
        /* Ensure modal content text is white */
        body.dark-mode .modal-content,
        body.dark-mode .modal-body,
        body.dark-mode .modal-header,
        body.dark-mode .modal-footer {
            color: #ffffff;
        }

        body {
            display: grid;
            grid-template-columns: 220px 1fr;
            grid-template-rows: 1fr auto;
            grid-template-areas:
                "sidebar main"
                "sidebar footer";
            height: 100vh;
        }

        /* ===== Sidebar ===== */
        nav.sidebar {
            grid-area: sidebar;
            background: rgba(255,255,255,0.6);
            backdrop-filter: blur(15px);
            border-right: 1.5px solid rgba(169,196,255,0.5);
            border-radius: 0 20px 20px 0;
            box-shadow: 0 8px 24px rgba(160,180,255,0.4);
            padding: 1rem;
            display: flex;
            flex-direction: column;
            overflow: hidden;
            position: relative;
            transition: width 0.3s ease, background 0.3s, color 0.3s;
            width: 220px;
        }

        nav.sidebar.collapsed {
            width: 60px;
        }

        nav.sidebar.collapsed .nav-link,
        nav.sidebar.collapsed form,
        nav.sidebar.collapsed .sidebar-header a.navbar-brand {
            display: none;
        }

        nav.sidebar .sidebar-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        nav.sidebar .nav-link {
            color: inherit;
            font-weight: 600;
            border-radius: 10px;
            padding: 10px 15px;
            margin-bottom: 5px;
            transition: background 0.3s;
        }

        nav.sidebar .nav-link:hover {
            background: rgba(160,180,255,0.2);
            color: #1f2a45;
        }

        nav.sidebar .btn-glass {
            background: rgba(160,180,255,0.2);
            backdrop-filter: blur(10px);
            border: none;
            color: inherit;
            font-weight: 600;
            width: 100%;
            margin-bottom: 5px;
            transition: background 0.3s, color 0.3s;
        }
        nav.sidebar .btn-glass:hover {
            background: rgba(160,180,255,0.4);
        }

        #toggleSidebar {
            cursor: pointer;
            font-size: 1.2rem;
            border: none;
            background: none;
            color: inherit;
            padding: 0;
            margin-left: 0.5rem;
        }

        /* ===== Main Content ===== */
        main.main-content {
            grid-area: main;
            padding: 2rem;
            background: rgba(255,255,255,0.6);
            backdrop-filter: blur(15px);
            border-radius: 20px;
            margin: 1rem;
            box-shadow: 0 8px 32px rgba(160,180,255,0.4);
            overflow-y: auto;
            max-height: calc(100vh - 2rem);
            transition: background 0.3s, color 0.3s;
        }

        /* ===== Footer ===== */
        footer.footer {
            grid-area: footer;
            background: rgba(255,255,255,0.4);
            backdrop-filter: blur(12px);
            border-top: 1.5px solid rgba(169,196,255,0.5);
            border-radius: 20px 20px 0 0;
            padding: 1rem;
            text-align: center;
            color: inherit;
            font-weight: 600;
            box-shadow: 0 -8px 24px rgba(160,180,255,0.25);
            transition: background 0.3s, color 0.3s;
        }

        /* ===== Dark Mode Toggle Switch ===== */
        .switch {
            position: relative;
            display: inline-block;
            width: 60px;
            height: 28px;
            margin-bottom: 1rem;
            font-weight: 600;
            user-select: none;
        }
        .switch input { display: none; }
        .slider {
            position: absolute;
            cursor: pointer;
            top: 0; left: 0; right: 0; bottom: 0;
            background-color: #ccc;
            transition: .4s;
            border-radius: 28px;
        }
        .slider::before {
            position: absolute;
            content: "";
            height: 22px; width: 22px;
            left: 3px; bottom: 3px;
            background-color: white;
            transition: .4s;
            border-radius: 50%;
        }
        input:checked + .slider { background-color: #2196F3; }
        input:checked + .slider::before { transform: translateX(32px); }
    </style>
</head>
<body>
    <!-- Sidebar -->
    <nav class="sidebar" aria-label="Sidebar navigation">
        <div class="sidebar-header mb-4">
            <a class="navbar-brand" asp-page="/Index">RazorApp</a>
            <button id="toggleSidebar" aria-label="Toggle sidebar">☰</button>
        </div>

        @if (SignInManager.IsSignedIn(User))
        {
            var user = await UserManager.GetUserAsync(User);

            @if (await UserManager.IsInRoleAsync(user, "Admin"))
            {
                <a class="nav-link" asp-page="/Admin/ManageUsers">User Management</a>
                <a class="nav-link" asp-page="/Product">Products</a>
            }

            @if (await UserManager.IsInRoleAsync(user, "OrderAssistant"))
            {
                <a class="nav-link" asp-page="/Product">Products</a>
            }

            @if (await UserManager.IsInRoleAsync(user, "Client"))
            {
                <a class="nav-link" asp-page="/Cart/Cart">Cart</a>
            }
            <form method="post" asp-page="/Account/Logout" class="mt-3">
                <button class="btn btn-glass w-100">Logout</button>
            </form>
        }
        else
        {
            <a class="btn btn-glass mb-2" asp-page="/Account/Login">Login</a>
            <a class="btn btn-glass" asp-page="/Account/Register">Register</a>
        }

    </nav>

     
    <!-- Main content -->
    <main class="main-content" role="main" tabindex="-1">
        @if (SignInManager.IsSignedIn(User))
        {
            var user = await UserManager.GetUserAsync(User);
            var roles = string.Join(", ", await UserManager.GetRolesAsync(user));

            <div class="mb-4 p-3 text-center" style="background: rgba(160,180,255,0.2); border-radius:15px;">
                👋 Welcome, <strong>@user.UserName</strong>
            </div>
        }

            <!-- Dark Mode Toggle -->
        <div class="mt-auto d-flex align-items-center justify-content-between p-2">
            <span style="font-weight:600;"></span>
            <label class="switch mb-0">
                <input type="checkbox" id="darkModeToggle" />
                <span class="slider round"></span>
            </label>
        </div>

        @RenderBody()
    </main>

    <!-- Footer -->
    <footer class="footer">
        &copy; 2026 - RazorApp - <a asp-page="/Privacy">Privacy</a>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        // Sidebar toggle
        const toggleBtn = document.getElementById('toggleSidebar');
        const sidebar = document.querySelector('nav.sidebar');
        toggleBtn.addEventListener('click', () => {
            sidebar.classList.toggle('collapsed');
        });

        // Dark mode toggle
        const darkToggle = document.getElementById('darkModeToggle');

        // Apply saved preference
        if (localStorage.getItem('darkMode') === 'true') {
            document.body.classList.add('dark-mode');
            darkToggle.checked = true;
        }

        darkToggle.addEventListener('change', () => {
            document.body.classList.toggle('dark-mode');
            localStorage.setItem('darkMode', document.body.classList.contains('dark-mode'));
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>