@page
@model RazorApp.Pages.Payment.PaymentPortalModel
@{
    ViewData["Title"] = "Fake Payment Portal";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">

<div class="container mt-5" style="max-width: 500px;">
    <h2 class="mb-4 text-center">💳 Payment Portal</h2>

    <div class="text-center mb-4">
        <i class="bi bi-credit-card-fill" style="font-size: 6rem; color:#f3912e;"></i>
    </div>

    <p>Order ID: <strong>@Model.OrderId</strong></p>
    <p>Total Amount: <strong>R @Model.Total</strong></p>

    <form method="post">
        <div class="mb-3">
            <label for="BankAccount" class="form-label">Bank Account Number</label>
            <input type="text" name="BankAccount" id="BankAccount" class="form-control" placeholder="5-9 digit account" required />
        </div>

        <div class="mb-3">
            <label for="PaymentStatus" class="form-label">Select Payment Status (optional)</label>
            <select name="PaymentStatus" id="PaymentStatus" class="form-select">
                <option value="Success">Success</option>
                <option value="Fail">Fail</option>
            </select>
        </div>

        <button type="submit" class="btn btn-success w-100">Submit Payment</button>
    </form>
</div>
