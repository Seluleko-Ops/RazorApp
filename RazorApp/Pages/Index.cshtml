@page
@model RazorApp.Pages.IndexModel
@{
    ViewData["Title"] = "Home page";
}

<div class="container my-5">
    <h2 class="mb-4 text-center text-glass-title">Items</h2>
    <div class="row g-4">
        @foreach (var product in Model.Products)
        {
            <div class="col-md-4">
                <div class="glass-card p-3 shadow-sm">
                    <img src="@(string.IsNullOrEmpty(product.ImagePath) ? "/images/placeholder.png" : "/images/" + product.ImagePath)"
                         alt="@product.ProductName"
                         class="img-fluid rounded mb-3"
                         style="height:200px; object-fit:cover;" />
                    <h5 class="text-glass-title">@product.ProductName</h5>
                    <p class="text-glass-stock">In Stock: @product.Stock</p>
                </div>
            </div>
        }
    </div>
</div>

<style>
    .glass-card {
        background: rgba(255, 255, 255, 0.25);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border-radius: 20px;
        border: 1.5px solid rgba(160, 180, 255, 0.4);
        box-shadow: 0 8px 24px rgba(160, 180, 255, 0.25);
        color: #2e3a59;
        height: 100%;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
    }

    .text-glass-title {
        color: #3a4a7a;
        font-weight: 600;
    }

    .text-glass-stock {
        color: #506484;
        font-weight: 500;
    }

</style>